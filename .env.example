# 로컬 개발용 환경변수 템플릿
# 복사: cp .env.example .env  (Windows: copy .env.example .env)
# 각자 환경에 맞게 경로 수정 후 사용.
# Docker 빌드 시에는 Dockerfile의 ENV가 우선 적용되므로 이 파일은 무시됨.

# ── 서빙 (web/) ──
# ONNX / YOLO 모델 디렉토리 (vgg16_full.onnx, best.pt 등 위치)
MODEL_DIR=/absolute/path/to/model
# 정적 파일 디렉토리 (index.html)
STATIC_DIR=/absolute/path/to/static
# YOLO confidence threshold
YOLO_CONF_THRESHOLD=0.5

# ── 배치 추출 (workFile/batch_extract.py) ──
# images_*.csv 와 결과 CSV가 저장될 상위 디렉토리
CLASSIFY_DIR=/absolute/path/to/classify
# 원본 이미지 루트 디렉토리
IMG_DIR=/absolute/path/to/upload
# 멀티프로세스 워커 수
NUM_WORKERS=6

# ── LabelMe 전처리 (workFile/preprocess_data.py) ──
# LabelMe JSON + 원본 이미지 디렉토리
SOURCE_DIR=/absolute/path/to/marqvision/file
# YOLO 데이터셋 출력 디렉토리
OUTPUT_DIR=/absolute/path/to/yolo_dataset
